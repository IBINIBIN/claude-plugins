{
  "mcpServers": {
    "tapd_mcp_http": {
      "type": "http",
      "url": "http://mcp-idc.tapd.woa.com/mcp/",
      "headers": {
        "X-Tapd-Access-Token": "${CLAUDE_ENV_TAPD_API_KEY}"
      }
    },
    "Figma": {
      "command": "npx",
      "args": ["-y", "figma-developer-mcp", "--figma-api-key=${CLAUDE_ENV_FIGMA_API_KEY}", "--stdio"]
    },
    "chrome-devtools": {
      "command": "npx",
      "args": ["chrome-devtools-mcp@latest", "--autoConnect", "--usageStatistics=false", "--performanceCrux=false"]
    }
  }
}
